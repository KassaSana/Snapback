# Snapback .gitignore

# ============================================
# PRIVACY: Never commit user data or logs
# ============================================
*.log
*.mmap
productivity_data/
events_*.bin
!samples/events_demo.bin
user_data/

# ============================================
# Rust / Tauri
# ============================================
src-tauri/target/
.cargo-target/
**/*.rs.bk

# ============================================
# Python
# ============================================
ml/venv/
ml/__pycache__/
ml/*.pyc
ml/.pytest_cache/
ml/.coverage
ml/htmlcov/
ml/dist/
ml/build/
ml/*.egg-info/

# ML Models (too large for git)
ml/models/*.pkl
ml/models/*.pt
ml/models/*.onnx
ml/models/*.h5
ml/checkpoints/
ml/artifacts/

# Training data
ml/data/*.csv
ml/data/*.parquet

# ============================================
# Node / React
# ============================================
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.next/
frontend/.cache/
frontend/.env.local

# ============================================
# IDEs and Editors
# ============================================
.vscode/
.idea/
.claude/
*.swp
*.swo
*~
.DS_Store

# ============================================
# Logs and Temp Files
# ============================================
*.tmp
*.temp
.env

# ============================================
# OS Files
# ============================================
Thumbs.db
desktop.ini
