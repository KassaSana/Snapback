{
  "name": "snapback",
  "private": true,
  "version": "0.2.0",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "test": "npm run test --prefix frontend",
    "typecheck": "npm run typecheck --prefix frontend",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "setup": "npm install && npm install --prefix frontend",
    "tauri:build": "tauri build",
    "tauri:build:nsis": "tauri build --bundles nsis",
    "tauri:build:dmg": "tauri build --bundles dmg",
    "icons:generate": "node tools/make-square-icon.mjs && tauri icon app-icon-square.png"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "sharp": "^0.34.3"
  }
}
